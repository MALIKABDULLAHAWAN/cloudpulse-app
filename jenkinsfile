pipeline {
    agent any

    environment {
        DOCKER_CREDS = "dockerhub-credentials"
        GITHUB_CREDS = "github-credentials"

        DOCKER_USER = "saazhoonmain"
        GITHUB_USER = "MALIKABDULLAHAWAN"

        PYTHON_IMAGE = "${DOCKER_USER}/cloudpulse-python"
        FRONTEND_IMAGE = "${DOCKER_USER}/cloudpulse-frontend"

        TAG = "v1.0.${env.BUILD_NUMBER}"
    }

    stages {
        stage('Build Python Image') {
            steps {
                script {
                    echo "Building Python Image (backend + worker)..."
                    docker.build("${PYTHON_IMAGE}:${TAG}", "-f Dockerfile.python .")
                }
            }
        }

        stage('Build Frontend Image') {
            steps {
                script {
                    echo "Building Frontend Image..."
                    docker.build("${FRONTEND_IMAGE}:${TAG}", "-f Dockerfile.frontend .")
                }
            }
        }

        stage('Push Images to Registry') {
            steps {
                script {
                    docker.withRegistry("https://index.docker.io/v1/", DOCKER_CREDS) {
                        // Push versioned tags
                        docker.image("${PYTHON_IMAGE}:${TAG}").push()
                        docker.image("${FRONTEND_IMAGE}:${TAG}").push()

                        // Also push as 'latest' (re-tags the same built image, no rebuild)
                        docker.image("${PYTHON_IMAGE}:${TAG}").push('latest')
                        docker.image("${FRONTEND_IMAGE}:${TAG}").push('latest')
                    }
                }
            }
        }

        stage('Deploy locally with Docker Compose') {
            steps {
                script {
                    echo "Deploying application locally using Docker Compose..."
                    // We can just pull the latest images we just pushed and run docker-compose
                    sh '''
                        docker-compose down || true
                        docker-compose pull
                        docker-compose up -d
                    '''
                }
            }
        }
    }
}